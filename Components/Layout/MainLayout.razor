@inherits LayoutComponentBase

<div class="min-h-screen flex flex-col bg-slate-50">
    <!-- Premium Header -->
    <header class="bg-white border-b border-slate-200 shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-700 text-white flex items-center justify-center font-bold text-xl shadow-lg shadow-blue-500/30">
                        SM
                    </div>
                    <div>
                        <h1 class="text-xl font-bold text-slate-900 tracking-tight">Saint Mary's</h1>
                        <p class="text-xs font-medium text-slate-500 uppercase tracking-widest">Recruitment Portal</p>
                    </div>
                </div>
                <nav class="hidden md:flex gap-8">
                    <a href="/" class="text-sm font-semibold text-slate-600 hover:text-blue-600 transition-colors">Jobs</a>
                    <a href="/hr" class="text-sm font-semibold text-slate-600 hover:text-blue-600 transition-colors">HR Portal</a>
                </nav>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
        @Body
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-200 py-8 mt-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-slate-500">
            &copy; @DateTime.Now.Year Saint Mary's Orthodox College. All rights reserved.
        </div>
    </footer>
</div>
