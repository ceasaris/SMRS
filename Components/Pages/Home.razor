@page "/"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using SMRS.Web.Data
@inject SmrsDbContext Db

<PageTitle>Careers - Saint Mary's Recruitment System</PageTitle>

<div class="bg-indigo-900 text-white py-24 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-20"></div>
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue-500 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-indigo-500 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob animation-delay-2000"></div>
    
    <div class="max-w-4xl mx-auto text-center relative z-10">
        <h1 class="text-5xl font-extrabold tracking-tight mb-6">Shape the Future of Education</h1>
        <p class="text-xl text-indigo-100 mb-10 max-w-2xl mx-auto leading-relaxed">Join our vibrant community of educators and professionals dedicated to excellence. Discover your next career opportunity at Saint Mary's Orthodox College.</p>
        <a href="#jobs" class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-lg font-medium rounded-full text-indigo-900 bg-white hover:bg-indigo-50 shadow-xl hover:shadow-indigo-500/20 transition-all transform hover:-translate-y-1">
            View Open Positions
        </a>
    </div>
</div>

<div id="jobs" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="mb-12 flex justify-between items-end">
        <div>
            <h2 class="text-3xl font-bold text-slate-900">Current Openings</h2>
            <p class="mt-2 text-slate-500 text-lg">Find the perfect role that matches your expertise, or submit a general application.</p>
        </div>
    </div>

    @if (Listings == null)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
        </div>
    }
    else
    {
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            
            <!-- General Application Card (Always visible) -->
            <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl border border-blue-100 shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col overflow-hidden group">
                <div class="absolute top-0 right-0 -mt-4 -mr-4 w-24 h-24 bg-blue-200 rounded-full mix-blend-multiply filter blur-xl opacity-50 group-hover:opacity-70 transition-opacity"></div>
                <div class="p-6 flex-grow relative z-10">
                    <div class="inline-block p-3 bg-white rounded-2xl shadow-sm text-blue-600 mb-4">
                        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H14" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-blue-700 transition-colors">General Application</h3>
                    <p class="text-slate-600 line-clamp-3 text-sm mb-4">
                        Submit your resume for future consideration. We are always looking for exceptional talent to join our team.
                    </p>
                </div>
                <div class="px-6 py-4 bg-white/50 backdrop-blur-sm border-t border-blue-100 flex justify-between items-center relative z-10">
                    <span class="text-sm font-medium text-slate-600">Always Open</span>
                    <a href="/verify" class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 shadow-sm hover:shadow transition-all">
                        Apply Now
                    </a>
                </div>
            </div>

            <!-- HR Job Listings -->
            @foreach (var listing in Listings)
            {
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 flex flex-col overflow-hidden group">
                    <div class="p-6 flex-grow">
                        <div class="flex items-center justify-between mb-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-800">
                                @listing.Position?.Department?.DepartmentName
                            </span>
                            <span class="text-sm text-slate-500">
                                @listing.PostedAt.ToString("MMM dd, yyyy")
                            </span>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-indigo-600 transition-colors">@listing.Position?.PositionName</h3>
                        <p class="text-slate-600 line-clamp-2 text-sm mb-4">
                            @listing.Notes
                        </p>
                    </div>
                    <div class="px-6 py-4 bg-slate-50 border-t border-slate-100 flex justify-between items-center">
                        <span class="text-sm font-medium text-slate-600">Full-time</span>
                        <a href="/verify/@listing.ListingId" class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-slate-900 hover:bg-slate-800 shadow-sm hover:shadow transition-all">
                            Apply Now
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<PositionListing>? Listings;

    protected override async Task OnInitializedAsync()
    {
        Listings = await Db.PositionListings
            .Include(l => l.Position)
                .ThenInclude(p => p.Department)
            .Include(l => l.Position)
                .ThenInclude(p => p.JobRole)
            .Where(l => l.Status == "Open")
            .OrderByDescending(l => l.PostedAt)
            .ToListAsync();
    }
}
