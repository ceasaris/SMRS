@page "/verify/{ListingId:int?}"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using SMRS.Web.Data
@using SMRS.Web.Services
@inject SmrsDbContext Db
@inject NavigationManager Nav
@inject IEmailService EmailService

<PageTitle>Verify Email - SMRS</PageTitle>

<div class="min-h-screen bg-slate-50 py-20 px-4 sm:px-6 lg:px-8 flex flex-col items-center">
    <div class="max-w-md w-full bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-200">
        <div class="bg-indigo-600 px-8 py-8 text-white relative overflow-hidden">
            <div class="absolute top-0 right-0 -mt-4 -mr-4 w-24 h-24 bg-blue-500 rounded-full mix-blend-multiply filter blur-xl opacity-50"></div>
            <h2 class="text-2xl font-bold mb-2 relative z-10">Start Your Application</h2>
            <p class="text-indigo-100 text-sm relative z-10">
                @(Listing != null ? $"Applying for: {Listing.Position?.PositionName}" : "General Application")
            </p>
        </div>

        <div class="p-8">
            @if (TokenGenerated)
            {
                <div class="bg-green-50 text-green-800 p-6 rounded-2xl border border-green-200 text-center">
                    <svg class="mx-auto h-12 w-12 text-green-500 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <h3 class="text-xl font-bold mb-2">Check your email!</h3>
                    <p class="text-sm mb-6">We've sent a secure verification link to <strong>@Email</strong>. This link will expire in 24 hours.</p>
                    
                    <div class="mt-6 p-4 bg-yellow-50 border border-yellow-200 rounded-xl text-left">
                        <p class="text-xs font-semibold text-yellow-800 uppercase mb-2">Development Mode:</p>
                        <p class="text-sm text-yellow-700 mb-3">If SMTP fails, use this direct link to continue:</p>
                        <a href="@VerificationLink" class="block text-center px-4 py-2 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 transition-colors">
                            Continue to Application
                        </a>
                    </div>
                </div>
            }
            else
            {
                <form @onsubmit="GenerateToken">
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
                            <input type="text" @bind="FullName" required class="w-full rounded-xl border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 bg-slate-50 p-3 border" placeholder="e.g. Jane Doe" />
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-1">Email Address</label>
                            <input type="email" @bind="Email" required class="w-full rounded-xl border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 bg-slate-50 p-3 border" placeholder="you@example.com" />
                            <p class="mt-2 text-xs text-slate-500">We will send a secure link to this email to verify your identity before you begin the application.</p>
                        </div>

                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div class="p-3 bg-red-50 text-red-700 rounded-lg text-sm border border-red-200">
                                @ErrorMessage
                            </div>
                        }

                        <button type="submit" disabled="@IsLoading" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors disabled:opacity-50">
                            @if (IsLoading)
                            {
                                <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                <span>Sending...</span>
                            }
                            else
                            {
                                <span>Send Verification Link</span>
                            }
                        </button>
                    </div>
                </form>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int? ListingId { get; set; }
    
    private PositionListing? Listing;
    
    private string FullName { get; set; } = "";
    private string Email { get; set; } = "";
    private string ErrorMessage { get; set; } = "";
    
    private bool IsLoading = false;
    private bool TokenGenerated = false;
    private string VerificationLink { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        if (ListingId.HasValue)
        {
            Listing = await Db.PositionListings
                .Include(l => l.Position)
                .FirstOrDefaultAsync(l => l.ListingId == ListingId.Value);
                
            if (Listing == null)
            {
                Nav.NavigateTo("/");
            }
        }
    }

    private async Task GenerateToken()
    {
        IsLoading = true;
        ErrorMessage = "";
        
        try
        {
            if (ListingId.HasValue)
            {
                var existingApp = await Db.Applications
                    .AnyAsync(a => a.ListingId == ListingId.Value && a.ApplicantEmail == Email && a.Status != "Rejected");
                    
                if (existingApp)
                {
                    ErrorMessage = "You have already applied for this position.";
                    IsLoading = false;
                    return;
                }
            }

            var tokenValue = Guid.NewGuid().ToString("N");
            
            var token = new Token
            {
                TokenValue = tokenValue,
                ApplicantEmail = Email,
                ApplicantName = FullName,
                ListingId = ListingId,
                CreatedAt = DateTime.UtcNow,
                ExpiresAt = DateTime.UtcNow.AddHours(24),
                IsUsed = false
            };
            
            Db.Tokens.Add(token);
            await Db.SaveChangesAsync();
            
            VerificationLink = $"{Nav.BaseUri}apply/{(ListingId?.ToString() ?? "")}?token={tokenValue}";
            
            await EmailService.SendVerificationEmailAsync(Email, FullName, VerificationLink);
            
            TokenGenerated = true;
        }
        catch (Exception)
        {
            ErrorMessage = "An error occurred. Please try again later.";
        }
        finally
        {
            IsLoading = false;
        }
    }
}
