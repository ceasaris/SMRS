@page "/hr"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using SMRS.Web.Data
@inject SmrsDbContext Db
@inject NavigationManager Nav

<PageTitle>HR Dashboard - SMRS</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-slate-900">HR Dashboard</h1>
            <p class="mt-2 text-slate-600">Manage recruitment pipelines and applicant dossiers.</p>
        </div>
        <div class="flex items-center gap-4 bg-white px-6 py-4 rounded-2xl shadow-sm border border-slate-200">
            <div class="bg-blue-100 text-blue-600 p-3 rounded-xl">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-slate-500 uppercase tracking-wider">New Applications</p>
                <p class="text-2xl font-bold text-slate-900">@Applications?.Count(a => a.Status == "Submitted")</p>
            </div>
        </div>
    </div>

    @if (Applications == null)
    {
        <div class="flex justify-center py-20">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
        </div>
    }
    else
    {
        <div class="bg-white shadow-sm border border-slate-200 rounded-2xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Applicant</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Position</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Date</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-200">
                        @foreach (var app in Applications)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="h-10 w-10 rounded-full bg-gradient-to-br from-indigo-100 to-blue-200 flex items-center justify-center text-blue-700 font-bold">
                                            @app.ApplicantName.Substring(0, 1)
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-medium text-slate-900">@app.ApplicantName</div>
                                            <div class="text-sm text-slate-500">@app.ApplicantEmail</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-slate-900">@(app.PositionListing?.Position?.PositionName ?? "General Application")</div>
                                    <div class="text-sm text-slate-500">@(app.PositionListing?.Position?.Department?.DepartmentName ?? "-")</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                    @app.SubmittedAt?.ToString("MMM dd, yyyy")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full 
                                        @(app.Status == "Submitted" ? "bg-amber-100 text-amber-800" : 
                                          app.Status == "Considered" ? "bg-blue-100 text-blue-800" :
                                          app.Status == "Shortlisted" ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                                        @app.Status
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium flex gap-2">
                                    @if (app.Status == "Submitted")
                                    {
                                        <button @onclick="@(() => UpdateStatus(app, "Considered"))" class="text-blue-600 hover:text-blue-900 bg-blue-50 px-3 py-1 rounded-md transition-colors">Consider</button>
                                        <button @onclick="@(() => UpdateStatus(app, "Rejected"))" class="text-red-600 hover:text-red-900 bg-red-50 px-3 py-1 rounded-md transition-colors">Reject</button>
                                    }
                                    else if (app.Status == "Considered")
                                    {
                                        <button @onclick="@(() => UpdateStatus(app, "Shortlisted"))" class="text-green-600 hover:text-green-900 bg-green-50 px-3 py-1 rounded-md transition-colors">Shortlist</button>
                                        <button @onclick="@(() => UpdateStatus(app, "Rejected"))" class="text-red-600 hover:text-red-900 bg-red-50 px-3 py-1 rounded-md transition-colors">Reject</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!Applications.Any())
                {
                    <div class="text-center py-10 text-slate-500">No applications found.</div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<Application>? Applications;

    protected override async Task OnInitializedAsync()
    {
        await LoadApplications();
    }

    private async Task LoadApplications()
    {
        Applications = await Db.Applications
            .Include(a => a.PositionListing)
                .ThenInclude(l => l.Position)
                    .ThenInclude(p => p.Department)
            .OrderByDescending(a => a.SubmittedAt)
            .ToListAsync();
    }

    private async Task UpdateStatus(Application app, string newStatus)
    {
        app.Status = newStatus;
        Db.Applications.Update(app);
        await Db.SaveChangesAsync();
        await LoadApplications();
    }
}
